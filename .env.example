# ==============================================================================
# MICROSERVICES ENVIRONMENT VARIABLES CONFIGURATION TEMPLATE
# Copy this file to `.env` in the same directory and fill in your credentials.
# ==============================================================================

# ------------------------------------------------------------------------------
# CENTRAL CONFIG SERVER CONFIGURATION
# ------------------------------------------------------------------------------
# Address of the config server.
# For running locally (outside Docker), set this to: http://localhost:8888
# For running inside Docker, set this to: http://config-server:8888
CONFIG_SERVER_URL=http://localhost:8888

# ------------------------------------------------------------------------------
# EUREKA DISCOVERY SERVER CONFIGURATION
# ------------------------------------------------------------------------------
# Service Discovery Server (Eureka) endpoint.
# For running locally: http://localhost:8761/eureka
# For running inside Docker: http://discovery-service:8761/eureka
EUREKA_SERVER_URL=http://localhost:8761/eureka
EUREKA_HOSTNAME=localhost

# ------------------------------------------------------------------------------
# MONGODB ATLAS CONFIGURATION (Used by customer-service and notification-service)
# ------------------------------------------------------------------------------
# Provide your MongoDB Atlas Connection URI here.
# Format: mongodb+srv://<username>:<password>@<cluster-url>/<db-name>?retryWrites=true&w=majority
# Notice: Replace '<db-name>' with the service database name ('customer' or 'notification')
# OR use a single base URI and specify the dbName dynamically in your Spring boot properties if needed.
# Since Spring Boot parses the URI, it's best to configure the full URIs for each service.
# If you configure a single global MONGODB_URI below, it will default both services to that database,
# so we recommend setting them separately in your environment or overriding them.
# To keep it simple, we configured the spring boot configs to read MONGODB_URI.
MONGODB_URI=mongodb+srv://<username>:<password>@your-cluster.mongodb.net/ecommerce?retryWrites=true&w=majority

# If you run locally with Docker Compose but want to use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@yourcluster.mongodb.net/customer?retryWrites=true&w=majority

# ------------------------------------------------------------------------------
# AWS RDS POSTGRESQL DATABASE CONFIGURATION (Used by order-service, payment-service, product-service)
# ------------------------------------------------------------------------------
# Database Connection URL (Optional - if set, overrides host/port/name below)
# DB_URL=jdbc:postgresql://your-rds-endpoint.amazonaws.com:5432/postgres

# Database Host (AWS RDS endpoint)
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# ------------------------------------------------------------------------------
# KAFKA MESSAGE BROKER CONFIGURATION
# ------------------------------------------------------------------------------
# For running locally: localhost:9092
# For running inside Docker: ms_kafka:9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ------------------------------------------------------------------------------
# DISTRIBUTED TRACING CONFIGURATION (Zipkin)
# ------------------------------------------------------------------------------
# For running locally: http://localhost:9411/api/v2/spans
# For running inside Docker: http://zipkin:9411/api/v2/spans
ZIPKIN_URL=http://localhost:9411/api/v2/spans

# ------------------------------------------------------------------------------
# MAIL SERVICE CONFIGURATION (MailDev)
# ------------------------------------------------------------------------------
# For running locally: localhost (port 1025)
# For running inside Docker: ms-mail-dev (port 1025)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=alibou
MAIL_PASSWORD=alibou

# ------------------------------------------------------------------------------
# INDIVIDUAL SERVICE PORT EXPOSURES (For reference, do not modify)
# ------------------------------------------------------------------------------
# Config Server:        8888
# Eureka Server:        8761
# Gateway Server:       8222
# Customer Service:     8090
# Notification Service: 8040
# Order Service:        8070
# Payment Service:      8060
# Product Service:      8050
